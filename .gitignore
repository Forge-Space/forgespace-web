# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# google ads checkpoint artifacts
marketing/google-ads/**/artifacts/

# google ads editor bulk upload (generated artifact)
