{
  "campaign_name": "forgespace_br_en_visibility_v3",
  "campaign_type": "Search",
  "goal": "Visibility and ecosystem discovery",
  "objective": "Project visibility for SMB builders and contributors",
  "network_settings": {
    "google_search": true,
    "search_partners": false,
    "display_expansion": false
  },
  "location_targeting": ["Brazil"],
  "language_targeting": ["English"],
  "location_options": {
    "target": "Presence",
    "exclude": "Presence"
  },
  "budget": {
    "currency": "BRL",
    "amount_per_day_brl": 10,
    "total_hard_stop_brl": 100,
    "usd_equivalent_context": {
      "amount_per_day_usd": 2,
      "total_hard_stop_usd": 20
    }
  },
  "bidding": {
    "strategy": "Maximize Clicks",
    "max_cpc_brl": 2.5
  },
  "ad_schedule": "all_day",
  "audience_mix_percent": {
    "smb_en": 45,
    "oss_en": 35,
    "startups_en": 20
  },
  "ad_groups": [
    {
      "name": "smb_en",
      "status": "enabled",
      "language": "en",
      "active_keyword_count_target": "6",
      "landing_page": "https://forgespace.co/",
      "notes": "IDP for startups moved to startups_en for better landing page match"
    },
    {
      "name": "oss_en",
      "status": "enabled",
      "language": "en",
      "active_keyword_count_target": "6",
      "landing_page": "https://forgespace.co/ecosystem"
    },
    {
      "name": "startups_en",
      "status": "enabled",
      "language": "en",
      "active_keyword_count_target": "6",
      "landing_page": "https://forgespace.co/startups",
      "notes": "Dedicated startup intent group — /startups has GitHub CTA for primary conversion"
    },
    {
      "name": "smb_pt",
      "status": "paused",
      "language": "pt-BR",
      "pause_reason": "forgespace.co is EN-only in this cycle"
    }
  ],
  "measurement": {
    "source": "GA4 import",
    "primary_event": "fs_cta_github_click",
    "secondary_events": [
      "fs_cta_contact_sales_click",
      "fs_cta_siza_click"
    ],
    "google_ads_goal_status": "Primary for fs_cta_github_click only",
    "ga4_custom_dimensions_required": ["cta_target", "cta_location"],
    "auto_tagging_required": true
  },
  "tracking": {
    "utm_campaign": "forgespace_br_en_visibility_v3",
    "ad_group_final_urls": {
      "smb_en": "https://forgespace.co/?utm_source=google&utm_medium=cpc&utm_campaign=forgespace_br_en_visibility_v3",
      "oss_en": "https://forgespace.co/ecosystem?utm_source=google&utm_medium=cpc&utm_campaign=forgespace_br_en_visibility_v3",
      "startups_en": "https://forgespace.co/startups?utm_source=google&utm_medium=cpc&utm_campaign=forgespace_br_en_visibility_v3"
    },
    "final_url_suffix": "utm_term={keyword}&utm_content={creative}&campaignid={campaignid}&adgroupid={adgroupid}&matchtype={matchtype}&device={device}"
  },
  "checkpoints_brl": [10, 30, 60],
  "stop_rules": {
    "ctr_below_percent_by_30_brl": 1.5,
    "no_primary_cta_by_60_brl": true,
    "repeated_irrelevant_terms_after_two_pruning_passes": true,
    "stop_early_if_poor_intent_quality_by_30_brl": true
  },
  "continue_rules": {
    "ctr_gte_percent_on_any_ad_group": 3,
    "primary_cta_conversions_gte": 1,
    "primary_cta_event": "fs_cta_github_click"
  }
}
