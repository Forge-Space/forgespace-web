{
  "name": "forgespace-web",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:docker": "next dev -H 0.0.0.0",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ads:google:prepublish": "bash scripts/google-ads-prepublish.sh",
    "ads:google:checkpoint": "node scripts/google-ads-checkpoint.mjs",
    "ads:google:publish-rsa": "node scripts/google-ads-publish-rsa.mjs",
    "ads:google:publish-keywords": "node scripts/google-ads-publish-keywords.mjs",
    "ads:google:generate-upload": "node scripts/google-ads-generate-upload.mjs",
    "check:cycles": "madge --circular --extensions ts,tsx src/",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-three/fiber": "^9.5.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.0",
    "next": "^15.5.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^5.86.0",
    "madge": "^8.0.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
